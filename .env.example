# Copy to .env and fill in. Never commit the real .env file (it's gitignored).

# Required by scripts/flowsage-predict (Claude vision calls).
ANTHROPIC_API_KEY=sk-ant-...

# Used by scripts/flowsage-graph and infra/docker-compose.yml.
# These defaults match docker-compose's local dev container; change them for
# any shared/non-local environment.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=flowsage_dev

POSTGRES_USER=flowsage
POSTGRES_PASSWORD=flowsage_dev
POSTGRES_DB=flowsage

# Used by backend/ (see backend/src/flowsage_backend/config.py).
DATABASE_URL=postgresql+asyncpg://flowsage:flowsage_dev@localhost:5432/flowsage
# Generate a real one with: openssl rand -hex 32
JWT_SECRET=dev-secret-change-me-before-deploying-32bytes
COOKIE_SECURE=false
REDIS_URL=redis://localhost:6379/0
UPLOAD_DIR=./data/uploads
# POST /v1/events (X-API-Key header) authenticates against per-workspace ApiKey
# rows, not an env var -- see `flowsage-backend create-api-key`.
